generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BackendMode {
  prisma_neon
  laravel_api
}

enum UserStatus {
  invited
  active
  suspended
  deactivated
}

enum ListingPurpose {
  rent
  sale
  short_stay
}

enum ListingStatus {
  draft
  pending_review
  approved
  rejected
  published
  archived
  suspended
}

enum FurnishingStatus {
  furnished
  semi_furnished
  unfurnished
}

enum AvailabilityStatus {
  available
  reserved
  occupied
  unavailable
}

enum InquiryStatus {
  new
  contacted
  viewing_scheduled
  viewed
  negotiating
  closed
  spam
  archived
}

enum ViewingStatus {
  requested
  confirmed
  rescheduled
  completed
  cancelled
  no_show
}

enum ReviewStatus {
  pending
  approved
  rejected
  hidden
}

enum NotificationChannel {
  in_app
  email
  sms
}

enum NotificationState {
  unread
  read
  archived
}

enum PropertyOwnerType {
  landlord
  agent
  property_manager
}

enum ReportReason {
  fake_listing
  inaccurate_info
  suspicious_pricing
  scam_or_fraud
  duplicate_listing
  inappropriate_content
  already_taken
  other
}

enum ReportStatus {
  open
  investigating
  resolved
  dismissed
}

enum AuditLogLevel {
  info
  warning
  critical
}

model User {
  id                      String           @id @default(uuid()) @db.Uuid
  fullName                String
  email                   String           @unique
  phone                   String           @unique
  passwordHash            String
  status                  UserStatus       @default(active)
  emailVerifiedAt         DateTime?
  phoneVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  lastLoginIp             String?          @db.Inet
  avatarUrl               String?
  isImpersonatable        Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  deletedAt               DateTime?
  profile                 Profile?
  sessions                Session[]
  loginLogs               LoginLog[]
  userRoles               UserRole[]
  authoredProperties      Property[]       @relation("PropertyOwner")
  reviewedProperties      Property[]       @relation("PropertyReviewer")
  inquiries               Inquiry[]        @relation("InquirySender")
  viewingRequests         ViewingRequest[] @relation("ViewingRequester")
  favorites               Favorite[]
  comparisons             Comparison[]
  reviews                 Review[]         @relation("ReviewAuthor")
  notifications           Notification[]
  supportTickets          SupportTicket[]  @relation("SupportTicketRequester")
  assignedTickets         SupportTicket[]  @relation("SupportTicketAssignee")
  auditLogs               AuditLog[]       @relation("AuditActor")
  activityLogs            ActivityLog[]    @relation("ActivityActor")
  authoredBlogPosts       BlogPost[]       @relation("BlogAuthor")
  filedReports            Report[]         @relation("ReportReporter")
  resolvedReports         Report[]         @relation("ReportResolver")
}

model Profile {
  id                      String    @id @default(uuid()) @db.Uuid
  userId                  String    @unique @db.Uuid
  bio                     String?
  nationalIdNumber        String?
  preferredCountyId       String?   @db.Uuid
  preferredCityId         String?   @db.Uuid
  preferredBudgetMin      Decimal?  @db.Decimal(12, 2)
  preferredBudgetMax      Decimal?  @db.Decimal(12, 2)
  preferredPropertyType   String?
  companyName             String?
  jobTitle                String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  country                 String?
  postalCode              String?
  completionScore         Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id                String           @id @default(uuid()) @db.Uuid
  name              String           @unique
  guardName         String           @default("web")
  description       String?
  isSystem          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  rolePermissions   RolePermission[]
  userRoles         UserRole[]
}

model Permission {
  id                String           @id @default(uuid()) @db.Uuid
  name              String           @unique
  guardName         String           @default("web")
  description       String?
  group             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  rolePermissions   RolePermission[]
}

model UserRole {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  roleId            String    @db.Uuid
  assignedAt        DateTime  @default(now())
  assignedBy        String?   @db.Uuid
  role              Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id                String      @id @default(uuid()) @db.Uuid
  roleId            String      @db.Uuid
  permissionId      String      @db.Uuid
  grantedAt         DateTime    @default(now())
  permission        Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role              Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  sessionTokenHash  String    @unique
  refreshTokenHash  String    @unique
  userAgent         String?
  ipAddress         String?   @db.Inet
  lastSeenAt        DateTime?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id                String    @id @default(uuid()) @db.Uuid
  identifier        String
  tokenHash         String    @unique
  type              String
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([identifier, type])
}

model PasswordResetToken {
  id                String    @id @default(uuid()) @db.Uuid
  email             String
  tokenHash         String    @unique
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([email])
}

model LoginLog {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String?   @db.Uuid
  email             String?
  success           Boolean   @default(false)
  ipAddress         String?   @db.Inet
  userAgent         String?
  failureReason     String?
  createdAt         DateTime  @default(now())
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BackendSetting {
  id                    String       @id @default(uuid()) @db.Uuid
  activeMode            BackendMode  @default(prisma_neon)
  fallbackMode          BackendMode?
  version               Int          @default(1)
  lastSwitchedAt        DateTime?
  lastSwitchedByUserId  String?      @db.Uuid
  lastSyncAt            DateTime?
  switchNotes           String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model AuditLog {
  id                  String         @id @default(uuid()) @db.Uuid
  actorUserId         String?        @db.Uuid
  action              String
  entityType          String
  entityId            String?
  backendProcessedBy  BackendMode
  level               AuditLogLevel  @default(info)
  ipAddress           String?        @db.Inet
  userAgent           String?
  metadata            Json?
  createdAt           DateTime       @default(now())
  actor               User?          @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model ActivityLog {
  id                  String       @id @default(uuid()) @db.Uuid
  actorUserId         String?      @db.Uuid
  event               String
  subjectType         String?
  subjectId           String?
  backendProcessedBy  BackendMode
  metadata            Json?
  createdAt           DateTime     @default(now())
  actor               User?        @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
}

model County {
  id                String         @id @default(uuid()) @db.Uuid
  name              String         @unique
  slug              String         @unique
  code              String?        @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  cities            City[]
  neighborhoods     Neighborhood[]
  properties        Property[]
}

model City {
  id                String         @id @default(uuid()) @db.Uuid
  countyId          String         @db.Uuid
  name              String
  slug              String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  county            County         @relation(fields: [countyId], references: [id], onDelete: Cascade)
  neighborhoods     Neighborhood[]
  properties        Property[]

  @@unique([countyId, slug])
}

model Neighborhood {
  id                String         @id @default(uuid()) @db.Uuid
  countyId          String         @db.Uuid
  cityId            String?        @db.Uuid
  name              String
  slug              String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  city              City?          @relation(fields: [cityId], references: [id], onDelete: SetNull)
  county            County         @relation(fields: [countyId], references: [id], onDelete: Cascade)
  properties        Property[]

  @@unique([countyId, slug])
}

model PropertyType {
  id                String         @id @default(uuid()) @db.Uuid
  name              String         @unique
  slug              String         @unique
  description       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  properties        Property[]
}

model Amenity {
  id                String            @id @default(uuid()) @db.Uuid
  name              String            @unique
  slug              String            @unique
  category          String?
  icon              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  properties        PropertyAmenity[]
}

model Property {
  id                      String             @id @default(uuid()) @db.Uuid
  ownerId                 String             @db.Uuid
  propertyTypeId          String             @db.Uuid
  countyId                String             @db.Uuid
  cityId                  String?            @db.Uuid
  neighborhoodId          String?            @db.Uuid
  ownerType               PropertyOwnerType
  title                   String
  slug                    String             @unique
  summary                 String
  description             String
  listingPurpose          ListingPurpose
  listingStatus           ListingStatus      @default(draft)
  moderationStatus        ListingStatus      @default(draft)
  price                   Decimal            @db.Decimal(14, 2)
  deposit                 Decimal?           @db.Decimal(14, 2)
  serviceCharge           Decimal?           @db.Decimal(14, 2)
  billingPeriod           String?
  sizeValue               Decimal?           @db.Decimal(10, 2)
  sizeUnit                String?
  bedrooms                Int?
  bathrooms               Int?
  toilets                 Int?
  furnishingStatus        FurnishingStatus?
  petsAllowed             Boolean            @default(false)
  parkingSlots            Int?
  hasSecurityFeatures     Boolean            @default(false)
  hasWaterAvailability    Boolean            @default(true)
  hasInternetAvailability Boolean            @default(false)
  furnishedLabel          String?
  negotiable              Boolean            @default(false)
  latitude                Decimal?           @db.Decimal(10, 7)
  longitude               Decimal?           @db.Decimal(10, 7)
  addressLine1            String?
  addressLine2            String?
  featuredAt              DateTime?
  publishedAt             DateTime?
  expiresAt               DateTime?
  availableFrom           DateTime?
  occupancyStatus         AvailabilityStatus @default(available)
  moderationNotes         String?
  rejectionReason         String?
  submittedAt             DateTime?
  reviewedAt              DateTime?
  reviewedByUserId        String?            @db.Uuid
  ownershipDeclaredAt     DateTime?
  responsibilityAcceptedAt DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  deletedAt               DateTime?
  city                    City?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  county                  County             @relation(fields: [countyId], references: [id], onDelete: Restrict)
  neighborhood            Neighborhood?      @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  owner                   User               @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reviewedByUser          User?              @relation("PropertyReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  propertyType            PropertyType       @relation(fields: [propertyTypeId], references: [id], onDelete: Restrict)
  versions                PropertyVersion[]
  images                  PropertyImage[]
  documents               PropertyDocument[]
  prices                  PropertyPrice[]
  nearbyPlaces            PropertyNearbyPlace[]
  amenities               PropertyAmenity[]
  inquiries               Inquiry[]
  viewingRequests         ViewingRequest[]
  favorites               Favorite[]
  comparisons             Comparison[]
  reviews                 Review[]
  reports                 Report[]

  @@index([listingStatus, publishedAt])
  @@index([countyId, cityId, neighborhoodId])
  @@index([propertyTypeId, listingPurpose, price])
}

model PropertyVersion {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  versionNumber     Int
  payload           Json
  changedByUserId   String?     @db.Uuid
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, versionNumber])
}

model PropertyImage {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  storageKey        String
  url               String
  altText           String?
  position          Int         @default(0)
  isCover           Boolean     @default(false)
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, position])
}

model PropertyDocument {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  name              String
  storageKey        String
  mimeType          String
  sizeBytes         Int
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyPrice {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  amount            Decimal     @db.Decimal(14, 2)
  billingPeriod     String?
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, effectiveFrom])
}

model PropertyNearbyPlace {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  name              String
  category          String?
  distanceKm        Decimal?    @db.Decimal(6, 2)
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAmenity {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  amenityId         String      @db.Uuid
  createdAt         DateTime    @default(now())
  amenity           Amenity     @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
}

model Inquiry {
  id                String         @id @default(uuid()) @db.Uuid
  propertyId        String         @db.Uuid
  senderUserId      String?        @db.Uuid
  name              String
  email             String
  phone             String?
  message           String
  status            InquiryStatus  @default(new)
  assignedToUserId  String?        @db.Uuid
  spamScore         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  property          Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sender            User?          @relation("InquirySender", fields: [senderUserId], references: [id], onDelete: SetNull)
  messages          InquiryMessage[]
}

model InquiryMessage {
  id                String      @id @default(uuid()) @db.Uuid
  inquiryId         String      @db.Uuid
  senderUserId      String?     @db.Uuid
  message           String
  createdAt         DateTime    @default(now())
  inquiry           Inquiry     @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model ViewingRequest {
  id                String         @id @default(uuid()) @db.Uuid
  propertyId        String         @db.Uuid
  requesterUserId   String?        @db.Uuid
  name              String
  email             String
  phone             String?
  requestedFor      DateTime
  status            ViewingStatus  @default(requested)
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  property          Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requester         User?          @relation("ViewingRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
}

model Favorite {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  propertyId        String      @db.Uuid
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model Report {
  id                 String        @id @default(uuid()) @db.Uuid
  propertyId         String        @db.Uuid
  reporterUserId     String?       @db.Uuid
  reporterEmail      String?
  reason             ReportReason
  details            String?
  status             ReportStatus  @default(open)
  resolvedAt         DateTime?
  resolvedByUserId   String?       @db.Uuid
  resolutionNotes    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  property           Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reporter           User?         @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  resolvedBy         User?         @relation("ReportResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([propertyId])
}

model Comparison {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  propertyId        String      @db.Uuid
  createdAt         DateTime    @default(now())
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model Review {
  id                String        @id @default(uuid()) @db.Uuid
  propertyId        String?       @db.Uuid
  authorUserId      String?       @db.Uuid
  rating            Int
  title             String?
  body              String?
  status            ReviewStatus  @default(pending)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  author            User?         @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  property          Property?     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Notification {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String              @db.Uuid
  title             String
  body              String
  channel           NotificationChannel @default(in_app)
  state             NotificationState   @default(unread)
  payload           Json?
  sentAt            DateTime?
  readAt            DateTime?
  createdAt         DateTime            @default(now())
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, state, createdAt])
}

model BlogPost {
  id                String      @id @default(uuid()) @db.Uuid
  authorUserId      String?     @db.Uuid
  title             String
  slug              String      @unique
  excerpt           String?
  content           Json
  seoTitle          String?
  seoDescription    String?
  featuredImage     String?
  publishedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  author            User?       @relation("BlogAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
}

model Faq {
  id                String      @id @default(uuid()) @db.Uuid
  question          String
  answer            String
  category          String?
  sortOrder         Int         @default(0)
  isPublished       Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Page {
  id                String      @id @default(uuid()) @db.Uuid
  title             String
  slug              String      @unique
  content           Json
  seoTitle          String?
  seoDescription    String?
  isPublished       Boolean     @default(false)
  publishedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Setting {
  id                String      @id @default(uuid()) @db.Uuid
  key               String      @unique
  value             Json
  scope             String      @default("global")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Banner {
  id                String      @id @default(uuid()) @db.Uuid
  title             String
  imageUrl          String
  targetUrl         String?
  startsAt          DateTime?
  endsAt            DateTime?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Testimonial {
  id                String      @id @default(uuid()) @db.Uuid
  name              String
  role              String?
  company           String?
  quote             String
  avatarUrl         String?
  isPublished       Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Plan {
  id                String      @id @default(uuid()) @db.Uuid
  name              String
  slug              String      @unique
  price             Decimal     @db.Decimal(14, 2)
  billingInterval   String
  featureSet        Json
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Subscription {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  planId            String      @db.Uuid
  status            String
  startsAt          DateTime
  endsAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Invoice {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  invoiceNumber     String      @unique
  amount            Decimal     @db.Decimal(14, 2)
  status            String
  issuedAt          DateTime
  paidAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model FeaturePayment {
  id                String      @id @default(uuid()) @db.Uuid
  propertyId        String      @db.Uuid
  amount            Decimal     @db.Decimal(14, 2)
  status            String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model SupportTicket {
  id                String      @id @default(uuid()) @db.Uuid
  requesterUserId   String?     @db.Uuid
  assigneeUserId    String?     @db.Uuid
  subject           String
  description       String
  status            String      @default("open")
  priority          String      @default("normal")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  assignee          User?       @relation("SupportTicketAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  requester         User?       @relation("SupportTicketRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
}
